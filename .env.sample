# ─── Required ────────────────────────────────────────────────────────────────

# JWT (minimum 32 characters)
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-chars

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<supabase-anon-or-service-role-key>

# AI
OPENROUTER_KEY=<openrouter-api-key>

# ─── Optional: separate Supabase projects for auth / sessions ─────────────────
# Falls back to SUPABASE_URL / SUPABASE_KEY if not set
# SUPABASE_AUTH_URL=
# SUPABASE_AUTH_KEY=
# SESSIONS_SUPABASE_URL=
# SESSIONS_SUPABASE_KEY=

# ─── Optional: AI keys ────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_TRACING_API_KEY=
# PERPLEXITY_API_KEY=
# ALPHA_VANTAGE_API_KEY=        # defaults to a demo key if unset

# ─── Optional: MCP server URLs ───────────────────────────────────────────────
# WEATHER_MCP_SERVER_URL=http://localhost:11000/sse
# TIME_MCP_SERVER_URL=http://localhost:11001/sse

# ─── Optional: app / logging ─────────────────────────────────────────────────
# API_TITLE=Actors API
# API_VERSION=1.0.0
# DEBUG=false
# LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_FILE=logs/actors.log
# LOG_MAX_BYTES=10485760        # 10 MB
# LOG_BACKUP_COUNT=5
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
